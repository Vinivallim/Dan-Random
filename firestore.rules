rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['character', 'copyright', 'imageUrl', 'sourceUrl', 'userId', 'createdAt'])
        && data.keys().size() == 6
        && data.character is string && data.character.size() > 0 && data.character.size() <= 1000
        && data.copyright is string && data.copyright.size() > 0 && data.copyright.size() <= 1000
        && data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() <= 2000
        && data.sourceUrl is string && data.sourceUrl.size() > 0 && data.sourceUrl.size() <= 2000
        && data.userId == request.auth.uid
        && data.createdAt is timestamp;
    }

    match /users/{userId}/favorites/{favoriteId} {
      // Must be logged in, must be the owner to list
      allow list, get: if isSignedIn() && userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(userId)
        && isValidId(favoriteId)
        && userId == request.auth.uid
        && isValidFavorite(incoming())
        && incoming().createdAt == request.time;
        
      allow delete: if isSignedIn() && userId == request.auth.uid;
    }
  }
}
